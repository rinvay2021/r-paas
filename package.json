{
  "name": "r-paas",
  "private": true,
  "scripts": {
    "prepare": "husky install",
    "dev:admin": "pnpm --filter @r-paas/admin dev",
    "dev:renderer": "pnpm --filter @r-paas/renderer dev",
    "build:components": "pnpm --filter @r-paas/components build",
    "build:shared": "pnpm --filter @r-paas/shared build",
    "build:admin": "pnpm --filter @r-paas/admin build",
    "build:renderer": "pnpm --filter @r-paas/renderer build",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "lint:style": "stylelint \"**/*.{css,less}\"",
    "lint:style:fix": "stylelint \"**/*.{css,less}\" --fix",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "clean": "rimraf node_modules **/*/node_modules",
    "type-check": "tsc --noEmit",
    "commit": "git-cz",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.26.2",
    "@commitlint/cli": "^17.0.0",
    "@commitlint/config-conventional": "^17.0.0",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^14.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^18.0.0",
    "@types/react": "18.0.0",
    "@types/react-dom": "18.0.0",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "commitizen": "^4.3.0",
    "cross-env": "^7.0.3",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^8.0.0",
    "eslint-import-resolver-node": "^0.3.9",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-jest": "^27.2.1",
    "eslint-plugin-jsx-a11y": "^6.7.1",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-react": "^7.0.0",
    "eslint-plugin-react-hooks": "^4.0.0",
    "husky": "^8.0.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "less": "^4.1.3",
    "less-loader": "^12.2.0",
    "lint-staged": "^13.2.0",
    "prettier": "^2.8.7",
    "rimraf": "^4.4.1",
    "stylelint": "^15.4.0",
    "stylelint-config-prettier": "^9.0.5",
    "stylelint-config-standard": "^32.0.0",
    "terser": "^5.37.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@ant-design/icons": "5.0.0",
    "@ant-design/pro-components": "2.8.2",
    "ahooks": "^3.8.4",
    "antd": "5.22.5",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-router-dom": "6.10.0",
    "use-query-params": "^2.1.1"
  }
}
